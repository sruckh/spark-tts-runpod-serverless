# Spark-TTS RunPod Serverless Environment Variables
# Copy this file to .env and update with your actual values

# S3 Configuration (Required)
BUCKET_ENDPOINT_URL=https://your-bucket.s3.region.amazonaws.com
BUCKET_ACCESS_KEY_ID=your_access_key
BUCKET_SECRET_ACCESS_KEY=your_secret_key
S3_BUCKET_NAME=your-bucket-name

# Model Configuration
MODEL_PATH=/runpod-volume/Spark-TTS/pretrained_models/Spark-TTS-0.5B
DEVICE=cuda:0

# RunPod Configuration
RUNPOD_AI_API_KEY=your_runpod_api_key
RUNPOD_ENDPOINT_ID=your_endpoint_id

# HuggingFace Configuration (Optional)
HF_TOKEN=your_huggingface_token

# WhisperX Configuration
WHISPERX_MODEL=large-v3
WHISPERX_DEVICE=cuda
WHISPERX_BATCH_SIZE=16

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json

# Performance Configuration
MAX_CONCURRENT_REQUESTS=4
REQUEST_TIMEOUT=300
IDLE_TIMEOUT=60

# Security Configuration
ALLOWED_ORIGINS=*
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=3600

# Cache Configuration
CACHE_DIR=/runpod-volume/cache
CACHE_TTL=3600
ENABLE_MODEL_CACHE=true

# Audio Configuration
DEFAULT_SAMPLE_RATE=16000
MAX_AUDIO_DURATION=300
SUPPORTED_FORMATS=wav,mp3,flac

# Error Tracking (Optional)
SENTRY_DSN=your_sentry_dsn
ENVIRONMENT=production

# Development/Testing (Local Only)
LOCAL_TESTING=false
MOCK_S3=false
DEBUG_MODE=false