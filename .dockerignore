# Spark-TTS RunPod Serverless Docker Ignore
# Optimize container builds by excluding unnecessary files

# Version control
.git/
.gitignore
.github/
*.git*

# Python cache and compiled files
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
venv/
env/
ENV/
.venv/
.env/

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Environment and configuration files
.env
.env.local
.env.*.local
*.env

# Documentation and markdown files (except README-serverless.md)
*.md
!README-serverless.md
docs/
PLAYBOOKS/

# Test files and coverage
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
.coverage.*
coverage.xml
*.cover
*.py,cover
.hypothesis/

# Logs
*.log
logs/
.logs/

# Temporary files
tmp/
.tmp/
temp/
.temp/

# Model files (downloaded at runtime)
pretrained_models/
models/
checkpoints/
*.bin
*.safetensors
*.h5
*.pkl
*.pth
*.pt

# Large data files
src/demos/
*.wav
*.mp3
*.flac
*.m4a
*.aac
*.ogg

# Example and test files
example/
examples/
tests/
test_*

# Original requirements (we use requirements-serverless.txt)
requirements.txt

# Runtime files
runtime/

# Build artifacts
*.tar.gz
*.zip
*.rar

# Jupyter notebooks
*.ipynb
.ipynb_checkpoints/

# Node.js (if any)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Docker files (except the one we need)
docker-compose.yml
Dockerfile.*
!Dockerfile

# Project-specific excludes
webui.py
gradio_*
src/figures/
src/logo/

# GitHub-specific files
ARCHITECTURE.md
API.md
BUILD.md
CLAUDE.md
CONDUCTOR.md
CONFIG.md
CONTRIBUTING.md
DATA_MODEL.md
DESIGN.md
ERRORS.md
GOALS.md
JOURNAL.md
TASKS.md
TEST.md
UIUX.md

# Large unnecessary directories
.pytest_cache/
.mypy_cache/
.dmypy.json
dmypy.json

# OS-specific files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Desktop.ini